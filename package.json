{
  "name": "rlauncher",
  "version": "0.3.8",
  "description": "Unified game launcher - all your games in one place",
  "main": "dist-electron/main.js",
  "author": "Ryzz3nn",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && node node_modules/electron-builder/cli.js",
    "dist:win": "npm run build && node node_modules/electron-builder/cli.js --win",
    "dist:portable": "npm run build && node node_modules/electron-builder/cli.js --win portable"
  },
  "build": {
    "appId": "com.ryzz3nn.rlauncher",
    "productName": "rLauncher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "src/assets/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "rLauncher",
      "artifactName": "rLauncher-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "rLauncher-${version}-portable.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Ryzz3nn",
      "repo": "rLauncher"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
